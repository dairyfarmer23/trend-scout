# Copy to .env and fill in your keys. .env is gitignored.

# --- Required ---

# Telegram bot for script delivery + feedback loop
# Create a bot: https://t.me/BotFather  →  /newbot
TELEGRAM_BOT_TOKEN=
# Your personal chat ID. Run `python telegram_research_bot.py test` to find it,
# or message @userinfobot on Telegram.
TELEGRAM_CHAT_ID=

# Apify for TikTok scraping (free tier covers moderate use)
# https://apify.com → create account → Account → Integrations → API token
APIFY_API_KEY=

# OpenAI for script generation + conversational editing
OPENAI_API_KEY=

# --- Optional ---

# Tavily or Brave for web trend search (either one — Tavily preferred)
TAVILY_API_KEY=
BRAVE_API_KEY=

# Path to an Obsidian vault if you want the bot to write notes/memories there.
# Leave blank to disable vault writes.
VAULT_PATH=

# If you run trend-scout on a separate VPS and want the bot to pull from it,
# set VPS_HOST (e.g. root@your.host) and VPS_TREND_SCOUT (install path).
# Leave blank for single-machine setups.
VPS_HOST=
VPS_TREND_SCOUT=/opt/trend-scout

# Base directory for memory/data files. Defaults to this script's directory.
TREND_SCOUT_BASE=

# Override commands for scheduled runs (defaults to `python <script>.py`)
CALENDAR_CMD=
AUTO_RESEARCH_CMD=
